{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/book",
      "destination": "https://customer.moovs.app/nyc-lux-ride/request/new",
      "permanent": false
    },
    {
      "source": "/fleet/:name.jpg",
      "destination": "/fleet/:name.webp",
      "statusCode": 301
    },
    {
      "source": "/home.webp",
      "destination": "/hero-new.webp",
      "statusCode": 301
    }
  ]
}
